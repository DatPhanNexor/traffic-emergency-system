  "item": [
    {
      "name": "Function 26 - Get Incidents",
      "description": "Test cases for retrieving incidents from area office (Trụ sở)",
      "item": [
        {
          "name": "ITC_26.1 - Get incidents without login",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/incidents",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "incidents"
              ]
            },
            "description": "Trụ sở chưa đăng nhập - Should return 401"
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Should return 401 - Not Authenticated', function() {",
                  "    pm.response.to.have.status(401);",
                  "    pm.expect(pm.response.text()).to.include('session');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "ITC_26.2 - Get incidents when logged in",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/incidents",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "incidents"
              ]
            },
            "description": "Trụ sở đăng nhập - Should return 200 and incident data"
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Should return 200 - Success', function() {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response should be array', function() {",
                  "    pm.expect(pm.response.json()).to.be.an('array');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "ITC_26.3 - Get incidents with status 'Chờ xử lý' (Pending)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/incidents?status=pending",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "incidents"
              ],
              "query": [
                {
                  "key": "status",
                  "value": "pending"
                }
              ]
            },
            "description": "Trụ sở đăng nhập - Lấy sự cố chờ xử lý - Should return 200 with only pending incidents"
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Should return 200 - Success', function() {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('All incidents should have status = pending', function() {",
                  "    var incidents = pm.response.json();",
                  "    incidents.forEach(function(incident) {",
                  "        pm.expect(incident.status).to.equal('pending');",
                  "    });",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "ITC_26.4 - Get incidents with status 'Đang xử lý' (In Progress)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/incidents?status=in_progress",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "incidents"
              ],
              "query": [
                {
                  "key": "status",
                  "value": "in_progress"
                }
              ]
            },
            "description": "Trụ sở đăng nhập - Lấy sự cố đang xử lý - Should return 200 with only in-progress incidents"
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Should return 200 - Success', function() {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('All incidents should have status = in_progress', function() {",
                  "    var incidents = pm.response.json();",
                  "    incidents.forEach(function(incident) {",
                  "        pm.expect(incident.status).to.equal('in_progress');",
                  "    });",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "ITC_26.5 - Get incidents with invalid format",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/incidents?status=invalid_status",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "incidents"
              ],
              "query": [
                {
                  "key": "status",
                  "value": "invalid_status"
                }
              ]
            },
            "description": "Tìm kiếm sai định dạng - Should return 200 with empty array"
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Should return 200 - Success', function() {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response should be empty array', function() {",
                  "    var incidents = pm.response.json();",
                  "    pm.expect(incidents).to.be.an('array').that.is.empty;",
                  "});"
                ]
              }
            }
          ]
        }
      ]
