{
  "info": {
    "_postman_id": "itc-26-29-incident-management",
    "name": "ITC_26-29_Incident_Management",
    "description": "Test Cases for Incident Management (Quản lý Sự cố)\n- ITC_26: Get incidents with authentication\n- ITC_27: Update incident severity level\n- ITC_28: Change incident status\n- ITC_29: Get incident history",
