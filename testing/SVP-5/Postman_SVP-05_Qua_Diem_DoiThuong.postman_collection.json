{
	"info": {
		"_postman_id": "svp05-qua-diem-doithuong-v2",
		"name": "SVP-05 — Quà, Điểm & Đổi Thưởng",
		"description": "Collection kiểm thử Module Quà, Điểm, Đổi thưởng.\n\n⚡ Chạy folder [0. Auth & Setup] TRƯỚC để tự động lưu token.\n\nAdmin login: POST /admin/login → auto-save {{tokenAdmin}}\nUser sync: POST /api/auth/sync (dev-token) → auto-save {{tokenUser}}",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "0. Auth & Setup",
			"item": [
				{
					"name": "POST Admin Login → auto-save tokenAdmin",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status 200 — Login thành công', function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test('Auto-save tokenAdmin', function () {",
									"    var data = pm.response.json();",
									"    pm.expect(data).to.have.property('token');",
									"    pm.environment.set('tokenAdmin', data.token);",
									"    console.log('✅ tokenAdmin saved: ' + data.token.substring(0, 30) + '...');",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"admin@traffic.com\",\n    \"password\": \"Admin123@\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/admin/login",
							"host": ["{{baseUrl}}"],
							"path": ["admin", "login"]
						}
					}
				},
				{
					"name": "POST User Sync (dev-token) → auto-save tokenUser",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status 200 — Sync thành công', function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test('Auto-save tokenUser & uid', function () {",
									"    var data = pm.response.json();",
									"    pm.expect(data).to.have.property('uid');",
									"    pm.environment.set('uid', data.uid);",
									"    pm.environment.set('tokenUser', 'dev-token');",
									"    console.log('✅ tokenUser = dev-token, uid = ' + data.uid);",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"token\": \"dev-token\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/auth/sync",
							"host": ["{{baseUrl}}"],
							"path": ["api", "auth", "sync"]
						}
					}
				}
			]
		},
		{
			"name": "1. Quà — Danh sách (User)",
			"item": [
				{
					"name": "GET Lấy danh sách tất cả quà",
					"event": [{ "listen": "test", "script": { "exec": [
						"pm.test('Status 200', function () { pm.response.to.have.status(200); });",
						"pm.test('Response time < 2000ms', function () { pm.expect(pm.response.responseTime).to.be.below(2000); });",
						"pm.test('Response is array', function () { pm.expect(pm.response.json()).to.be.an('array'); });",
						"pm.test('Each item has required fields', function () {",
						"    var data = pm.response.json();",
						"    if (data.length > 0) {",
						"        pm.expect(data[0]).to.have.all.keys('id','ten','loai','diem','trangThai');",
						"    }",
						"});",
						"pm.test('loai is VOUCHER or SAN_PHAM', function () {",
						"    pm.response.json().forEach(function(i) { pm.expect(['VOUCHER','SAN_PHAM']).to.include(i.loai); });",
						"});"
					], "type": "text/javascript" } }],
					"request": { "method": "GET", "header": [],
						"url": { "raw": "{{baseUrl}}/api/qua/all", "host": ["{{baseUrl}}"], "path": ["api","qua","all"] }
					}
				}
			]
		},
		{
			"name": "2. Quà — Quản lý (Admin)",
			"item": [
				{
					"name": "GET Lấy danh sách quà (Admin)",
					"event": [{ "listen": "test", "script": { "exec": [
						"pm.test('Status 200', function () { pm.response.to.have.status(200); });",
						"pm.test('Response is array', function () { pm.expect(pm.response.json()).to.be.an('array'); });",
						"pm.test('Save last qua_id', function () {",
						"    var d = pm.response.json();",
						"    if (d.length > 0) { pm.environment.set('qua_id', d[d.length-1].id); console.log('qua_id = ' + d[d.length-1].id); }",
						"});"
					], "type": "text/javascript" } }],
					"request": { "method": "GET", "header": [
						{ "key": "Cookie", "value": "ADMIN_JWT={{tokenAdmin}}" }
					],
						"url": { "raw": "{{baseUrl}}/admin/quan-ly-qua/all", "host": ["{{baseUrl}}"], "path": ["admin","quan-ly-qua","all"] }
					}
				},
				{
					"name": "POST Thêm quà mới",
					"event": [{ "listen": "test", "script": { "exec": [
						"pm.test('Status 200', function () { pm.response.to.have.status(200); });",
						"pm.test('SUCCESS code', function () {",
						"    var d = pm.response.json();",
						"    pm.expect(d.code).to.eql('SUCCESS');",
						"});",
						"// Auto-fetch new qua_id",
						"pm.sendRequest({ url: pm.environment.get('baseUrl') + '/admin/quan-ly-qua/all', method: 'GET',",
						"    header: { 'Cookie': 'ADMIN_JWT=' + pm.environment.get('tokenAdmin') }",
						"}, function(err, res) {",
						"    if (!err) { var l = res.json(); if(l.length>0) { pm.environment.set('qua_id', l[l.length-1].id); console.log('✅ new qua_id = '+l[l.length-1].id); } }",
						"});"
					], "type": "text/javascript" } }],
					"request": { "method": "POST",
						"header": [{ "key": "Cookie", "value": "ADMIN_JWT={{tokenAdmin}}" }],
						"body": { "mode": "formdata", "formdata": [
							{ "key": "ten", "value": "Voucher Test Postman 50K", "type": "text" },
							{ "key": "loai", "value": "VOUCHER", "type": "text" },
							{ "key": "moTa", "value": "Voucher test từ Postman Runner", "type": "text" },
							{ "key": "diem", "value": "500", "type": "text" },
							{ "key": "giaTriGiamPercent", "value": "30", "type": "text" },
							{ "key": "giaTriToiDa", "value": "50000", "type": "text" },
							{ "key": "ngayKetThuc", "value": "2027-12-31T23:59", "type": "text" },
							{ "key": "trangThai", "value": "HOAT_DONG", "type": "text" }
						]},
						"url": { "raw": "{{baseUrl}}/admin/quan-ly-qua/add", "host": ["{{baseUrl}}"], "path": ["admin","quan-ly-qua","add"] }
					}
				},
				{
					"name": "PATCH Sửa thông tin quà",
					"event": [{ "listen": "test", "script": { "exec": [
						"pm.test('Status 200', function () { pm.response.to.have.status(200); });",
						"pm.test('Cập nhật thành công', function () { pm.expect(pm.response.text()).to.include('thành công'); });"
					], "type": "text/javascript" } }],
					"request": { "method": "PATCH",
						"header": [{ "key": "Cookie", "value": "ADMIN_JWT={{tokenAdmin}}" }],
						"body": { "mode": "formdata", "formdata": [
							{ "key": "ten", "value": "Voucher Updated by Postman", "type": "text" },
							{ "key": "diem", "value": "800", "type": "text" },
							{ "key": "moTa", "value": "Đã cập nhật bởi Postman", "type": "text" }
						]},
						"url": { "raw": "{{baseUrl}}/admin/quan-ly-qua/edit/{{qua_id}}", "host": ["{{baseUrl}}"], "path": ["admin","quan-ly-qua","edit","{{qua_id}}"] }
					}
				},
				{
					"name": "DELETE Xóa quà (Happy)",
					"event": [{ "listen": "test", "script": { "exec": [
						"pm.test('Status 200', function () { pm.response.to.have.status(200); });",
						"pm.test('Delete success', function () { pm.expect(pm.response.json().status).to.eql('success'); });"
					], "type": "text/javascript" } }],
					"request": { "method": "DELETE",
						"header": [{ "key": "Cookie", "value": "ADMIN_JWT={{tokenAdmin}}" }],
						"url": { "raw": "{{baseUrl}}/admin/quan-ly-qua/delete/{{qua_id}}", "host": ["{{baseUrl}}"], "path": ["admin","quan-ly-qua","delete","{{qua_id}}"] }
					}
				},
				{
					"name": "DELETE Xóa quà không tồn tại (Negative)",
					"event": [{ "listen": "test", "script": { "exec": [
						"pm.test('Status 404', function () { pm.response.to.have.status(404); });",
						"pm.test('Error response', function () { pm.expect(pm.response.json().status).to.eql('error'); });"
					], "type": "text/javascript" } }],
					"request": { "method": "DELETE",
						"header": [{ "key": "Cookie", "value": "ADMIN_JWT={{tokenAdmin}}" }],
						"url": { "raw": "{{baseUrl}}/admin/quan-ly-qua/delete/999999", "host": ["{{baseUrl}}"], "path": ["admin","quan-ly-qua","delete","999999"] }
					}
				}
			]
		},
		{
			"name": "3. Đổi Quà (User)",
			"item": [
				{
					"name": "POST Đổi điểm lấy quà (Happy)",
					"event": [{ "listen": "test", "script": { "exec": [
						"pm.test('Status 200', function () { pm.response.to.have.status(200); });",
						"pm.test('Response time < 3s', function () { pm.expect(pm.response.responseTime).to.be.below(3000); });",
						"pm.test('Đổi quà thành công', function () { pm.expect(pm.response.json().message).to.include('thành công'); });"
					], "type": "text/javascript" } }],
					"request": { "method": "POST",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{tokenUser}}" },
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": { "mode": "raw", "raw": "{\n    \"quaId\": 1,\n    \"soLuong\": 1\n}" },
						"url": { "raw": "{{baseUrl}}/api/qua/exchange", "host": ["{{baseUrl}}"], "path": ["api","qua","exchange"] }
					}
				},
				{
					"name": "POST Đổi quà — Không đủ điểm (Negative)",
					"event": [{ "listen": "test", "script": { "exec": [
						"pm.test('Status 400', function () { pm.response.to.have.status(400); });",
						"pm.test('Error message', function () { pm.expect(pm.response.json()).to.have.property('message'); });"
					], "type": "text/javascript" } }],
					"request": { "method": "POST",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{tokenUser}}" },
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": { "mode": "raw", "raw": "{\n    \"quaId\": 1,\n    \"soLuong\": 99999\n}" },
						"url": { "raw": "{{baseUrl}}/api/qua/exchange", "host": ["{{baseUrl}}"], "path": ["api","qua","exchange"] }
					}
				},
				{
					"name": "POST Đổi quà — Không Auth (Negative)",
					"event": [{ "listen": "test", "script": { "exec": [
						"pm.test('Status 401 or 400', function () { pm.expect(pm.response.code).to.be.oneOf([400,401]); });"
					], "type": "text/javascript" } }],
					"request": { "method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": { "mode": "raw", "raw": "{\n    \"quaId\": 1,\n    \"soLuong\": 1\n}" },
						"url": { "raw": "{{baseUrl}}/api/qua/exchange", "host": ["{{baseUrl}}"], "path": ["api","qua","exchange"] }
					}
				},
				{
					"name": "GET Xem túi quà của tôi",
					"event": [{ "listen": "test", "script": { "exec": [
						"pm.test('Status 200', function () { pm.response.to.have.status(200); });",
						"pm.test('Response is array', function () { pm.expect(pm.response.json()).to.be.an('array'); });",
						"pm.test('Each gift has fields', function () {",
						"    pm.response.json().forEach(function(i) {",
						"        pm.expect(i).to.have.property('quaId');",
						"        pm.expect(i).to.have.property('tenQua');",
						"        pm.expect(i).to.have.property('soLuong');",
						"    });",
						"});"
					], "type": "text/javascript" } }],
					"request": { "method": "GET",
						"header": [{ "key": "Authorization", "value": "Bearer {{tokenUser}}" }],
						"url": { "raw": "{{baseUrl}}/api/qua/my-gifts", "host": ["{{baseUrl}}"], "path": ["api","qua","my-gifts"] }
					}
				}
			]
		},
		{
			"name": "4. Đổi Tiền & Quyên Góp (User)",
			"item": [
				{
					"name": "POST Quyên góp",
					"event": [{ "listen": "test", "script": { "exec": [
						"pm.test('Status 200', function () { pm.response.to.have.status(200); });",
						"pm.test('Thành công', function () { pm.expect(pm.response.json().message).to.include('thành công'); });"
					], "type": "text/javascript" } }],
					"request": { "method": "POST",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{tokenUser}}" },
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": { "mode": "raw", "raw": "{\n    \"soDiemDoi\": 100,\n    \"loaiDoi\": \"QUYEN_GOP\"\n}" },
						"url": { "raw": "{{baseUrl}}/api/doi-tien/thuc-hien", "host": ["{{baseUrl}}"], "path": ["api","doi-tien","thuc-hien"] }
					}
				},
				{
					"name": "POST Đổi tiền",
					"event": [{ "listen": "test", "script": { "exec": [
						"pm.test('Status 200', function () { pm.response.to.have.status(200); });",
						"pm.test('Thành công', function () { pm.expect(pm.response.json().message).to.include('thành công'); });"
					], "type": "text/javascript" } }],
					"request": { "method": "POST",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{tokenUser}}" },
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": { "mode": "raw", "raw": "{\n    \"soDiemDoi\": 200,\n    \"loaiDoi\": \"DOI_TIEN\"\n}" },
						"url": { "raw": "{{baseUrl}}/api/doi-tien/thuc-hien", "host": ["{{baseUrl}}"], "path": ["api","doi-tien","thuc-hien"] }
					}
				},
				{
					"name": "POST Đổi tiền — Không đủ điểm (Negative)",
					"event": [{ "listen": "test", "script": { "exec": [
						"pm.test('Status 400', function () { pm.response.to.have.status(400); });",
						"pm.test('Error message', function () { pm.expect(pm.response.json()).to.have.property('message'); });"
					], "type": "text/javascript" } }],
					"request": { "method": "POST",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{tokenUser}}" },
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": { "mode": "raw", "raw": "{\n    \"soDiemDoi\": 999999,\n    \"loaiDoi\": \"QUYEN_GOP\"\n}" },
						"url": { "raw": "{{baseUrl}}/api/doi-tien/thuc-hien", "host": ["{{baseUrl}}"], "path": ["api","doi-tien","thuc-hien"] }
					}
				}
			]
		},
		{
			"name": "5. Lịch Sử Đổi Điểm",
			"item": [
				{
					"name": "GET Lịch sử cá nhân",
					"event": [{ "listen": "test", "script": { "exec": [
						"pm.test('Status 200', function () { pm.response.to.have.status(200); });",
						"pm.test('Is array', function () { pm.expect(pm.response.json()).to.be.an('array'); });",
						"pm.test('Fields check', function () {",
						"    pm.response.json().forEach(function(i) { pm.expect(i).to.have.property('soDiemDoi'); pm.expect(i).to.have.property('loaiDoi'); });",
						"});"
					], "type": "text/javascript" } }],
					"request": { "method": "GET",
						"header": [{ "key": "Authorization", "value": "Bearer {{tokenUser}}" }],
						"url": { "raw": "{{baseUrl}}/api/doi-tien/lich-su", "host": ["{{baseUrl}}"], "path": ["api","doi-tien","lich-su"] }
					}
				},
				{
					"name": "GET Lịch sử filter QUYEN_GOP",
					"event": [{ "listen": "test", "script": { "exec": [
						"pm.test('Status 200', function () { pm.response.to.have.status(200); });",
						"pm.test('All QUYEN_GOP', function () {",
						"    pm.response.json().forEach(function(i) { pm.expect(i.loaiDoi).to.eql('QUYEN_GOP'); });",
						"});"
					], "type": "text/javascript" } }],
					"request": { "method": "GET",
						"header": [{ "key": "Authorization", "value": "Bearer {{tokenUser}}" }],
						"url": { "raw": "{{baseUrl}}/api/doi-tien/lich-su?loai=QUYEN_GOP", "host": ["{{baseUrl}}"], "path": ["api","doi-tien","lich-su"], "query": [{ "key": "loai", "value": "QUYEN_GOP" }] }
					}
				},
				{
					"name": "GET Lịch sử tất cả (Admin)",
					"event": [{ "listen": "test", "script": { "exec": [
						"pm.test('Status 200', function () { pm.response.to.have.status(200); });",
						"pm.test('Is array', function () { pm.expect(pm.response.json()).to.be.an('array'); });"
					], "type": "text/javascript" } }],
					"request": { "method": "GET", "header": [],
						"url": { "raw": "{{baseUrl}}/api/doi-tien/lich-su/all", "host": ["{{baseUrl}}"], "path": ["api","doi-tien","lich-su","all"] }
					}
				},
				{
					"name": "GET Thống kê quỹ quyên góp",
					"event": [{ "listen": "test", "script": { "exec": [
						"pm.test('Status 200', function () { pm.response.to.have.status(200); });",
						"pm.test('tongGiaTri is number', function () { pm.expect(pm.response.json().tongGiaTri).to.be.a('number'); });",
						"pm.test('lichSuVinhDanh is array', function () { pm.expect(pm.response.json().lichSuVinhDanh).to.be.an('array'); });"
					], "type": "text/javascript" } }],
					"request": { "method": "GET", "header": [],
						"url": { "raw": "{{baseUrl}}/api/doi-tien/thong-ke-quy", "host": ["{{baseUrl}}"], "path": ["api","doi-tien","thong-ke-quy"] }
					}
				},
				{
					"name": "GET Lịch sử tổng hợp",
					"event": [{ "listen": "test", "script": { "exec": [
						"pm.test('Status 200', function () { pm.response.to.have.status(200); });",
						"pm.test('Is array', function () { pm.expect(pm.response.json()).to.be.an('array'); });"
					], "type": "text/javascript" } }],
					"request": { "method": "GET",
						"header": [{ "key": "Authorization", "value": "Bearer {{tokenUser}}" }],
						"url": { "raw": "{{baseUrl}}/api/lich-su/all", "host": ["{{baseUrl}}"], "path": ["api","lich-su","all"] }
					}
				}
			]
		}
	],
	"variable": [
		{ "key": "baseUrl", "value": "http://localhost:8082" }
	]
}
