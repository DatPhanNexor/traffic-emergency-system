    "description": "Collection kiểm thử hoàn chỉnh Module Quà, Điểm, Đổi thưởng.\n\n⚡ Chạy folder [0. Auth & Setup] TRƯỚC để tự động lưu token.\n\nAdmin login: POST /admin/login → auto-save {{tokenAdmin}}\nUser sync: POST /api/auth/sync (dev-token) → auto-save {{tokenUser}}\n\nBao gồm:\n- Happy path tests\n- Negative tests & Edge cases\n- Admin management endpoints\n- User endpoints",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "51380219",
    "_collection_link": "https://go.postman.co/collection/51380219-c579168a-6608-4092-a348-b2e55343c3a2?source=collection_link"
  },
  "item": [
    {
      "name": "0. Auth & Setup",
      "item": [
        {
          "name": "POST Admin Login → auto-save tokenAdmin",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 — Login thành công', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Auto-save tokenAdmin', function () {",
                  "    var data = pm.response.json();",
                  "    pm.expect(data).to.have.property('token');",
                  "    pm.environment.set('tokenAdmin', data.token);",
                  "    console.log('✅ tokenAdmin saved: ' + data.token.substring(0, 30) + '...');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"email\": \"admin@traffic.com\",\n    \"password\": \"Admin123@\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/admin/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "admin",
                "login"
              ]
            }
          },
          "response": []
        },
        {
          "name": "POST User Sync (dev-token) → auto-save tokenUser",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 — Sync thành công', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Auto-save tokenUser & uid', function () {",
                  "    var data = pm.response.json();",
                  "    pm.expect(data).to.have.property('uid');",
                  "    pm.environment.set('uid', data.uid);",
                  "    pm.environment.set('tokenUser', 'dev-token');",
                  "    console.log('✅ tokenUser = dev-token, uid = ' + data.uid);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"token\": \"dev-token\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/sync",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "sync"
              ]
            }
          },
          "response": []
        }
      ]
