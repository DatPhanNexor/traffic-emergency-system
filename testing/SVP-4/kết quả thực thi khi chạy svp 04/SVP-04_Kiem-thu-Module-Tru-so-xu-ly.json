                "history"
              ]
            },
            "description": "Lấy lịch sử sự cố thành công - Should return 200 with completed incidents"
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Should return 200 - Success', function() {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response should be array of completed incidents', function() {",
                  "    var incidents = pm.response.json();",
                  "    pm.expect(incidents).to.be.an('array');",
                  "    incidents.forEach(function(incident) {",
                  "        pm.expect(incident.status).to.equal('completed');",
                  "    });",
                  "});"
                ]
              }
            }
          ]
